{
  "expo": {
    "name": "ClearNight",
    "slug": "clearnight",
    "scheme": "clearnight",
    "version": "1.0.0",
    "buildNumber": "1",
    "orientation": "portrait",
    "icon": "./assets/clearnight-icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#04060e",
    "ios": {
      "bundleIdentifier": "com.clearnight.app",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ClearNight uses your location to show local dark-sky conditions and nearby stargazing spots.",
        "UIBackgroundModes": [
          "fetch",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.clearnight.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#04060e",
        "foregroundImage": "./assets/clearnight-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "splash": {
      "image": "./assets/clearnight-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#04060e"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ClearNight uses your location to show local dark-sky conditions and nearby stargazing spots."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/clearnight-icon.png",
          "color": "#7ef0d2"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "67acbb81-4fcf-43a8-a93b-b37833920d88"
      },
      "router": {}
    },
    "owner": "mplymale"
  }
}
